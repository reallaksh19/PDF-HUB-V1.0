+  static async movePagesAsBlock(
+    baseBytes: Uint8Array,
+    pageIndices: number[],
+    targetIndex: number,
+  ): Promise<Uint8Array> {
+    const srcDoc = await PDFDocument.load(baseBytes);
+    const pageCount = srcDoc.getPageCount();
+    const moving = normalizePageIndices(pageIndices);
