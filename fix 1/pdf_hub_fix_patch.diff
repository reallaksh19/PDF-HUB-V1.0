+    const order = srcDoc.getPageIndices();
+    const kept = order.filter((index) => !movingSet.has(index));
+    const insertAt = kept.findIndex((index) => index === targetIndex);
+    const nextOrder = [
+      ...kept.slice(0, insertAt < 0 ? kept.length : insertAt),
+      ...moving,
+      ...kept.slice(insertAt < 0 ? kept.length : insertAt),
+    ];
